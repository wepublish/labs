{
  "name": "labs",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "sync:gemeinden": "cp src/dorfkoenig/lib/gemeinden.json src/dorfkoenig/supabase/functions/_shared/gemeinden.json",
    "predev": "npm run sync:gemeinden",
    "prebuild": "npm run sync:gemeinden",
    "dev": "vite",
    "build": "vite build",
    "build:production": "vite build --mode production",
    "preview": "vite preview",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "new-app": "node scripts/create-app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:manual-upload": "deno test src/dorfkoenig/supabase/functions/_tests/shared/manual_upload_review_test.ts src/dorfkoenig/supabase/functions/_tests/shared/embeddings_dedup_test.ts",
    "smoke:dorfkoenig": "bash ./src/dorfkoenig/scripts/run-live-smokes.sh",
    "smoke:dorfkoenig:pipeline": "deno run -A ./src/dorfkoenig/supabase/functions/_tests/smoke/live_scout_pipeline_smoke.ts",
    "smoke:dorfkoenig:dedup": "deno run -A ./src/dorfkoenig/supabase/functions/_tests/smoke/live_canonical_dedup_smoke.ts",
    "supabase:dorfkoenig": "supabase --workdir ./src/dorfkoenig",
    "supabase:dorfkoenig:migration:list": "npm run supabase:dorfkoenig -- migration list",
    "supabase:dorfkoenig:check": "bash ./src/dorfkoenig/scripts/check-migration-state.sh",
    "deploy:dorfkoenig:schema": "npm run supabase:dorfkoenig:check && npm run supabase:dorfkoenig -- db push",
    "deploy:dorfkoenig:function": "bash ./src/dorfkoenig/scripts/deploy-functions.sh",
    "release:dorfkoenig:preflight": "npm run lint && npm run typecheck && npm run build",
    "bench:dorfkoenig": "tsx src/dorfkoenig/supabase/functions/_tests/bench/run.ts",
    "bench:manual-upload": "deno bench src/dorfkoenig/supabase/functions/_tests/shared/manual_upload_review_bench.ts",
    "ingest:feedback": "tsx src/dorfkoenig/scripts/ingest-feedback.ts",
    "submit:published": "tsx src/dorfkoenig/scripts/submit-published-draft.ts",
    "regenerate:past-drafts": "tsx src/dorfkoenig/scripts/regenerate-past-drafts.ts",
    "benchmark:subpages": "tsx src/dorfkoenig/scripts/benchmark-subpage-follow.ts",
    "repair:dedup": "tsx src/dorfkoenig/scripts/repair-dedup-regression.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.46.0",
    "jose": "^5.9.0",
    "lucide-svelte": "^0.574.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.46.0",
    "glob": "^11.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
